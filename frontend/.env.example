# Backend API URL
# Lokal: http://127.0.0.1:8000/api
# Canlı (Vercel env): https://gamelogd-production.up.railway.app/api
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Auth token depolama modu:
#   header (varsayılan) -> token JS cookie'de, Authorization header ile gönderilir.
#                          Frontend ile API farklı domain'de olduğunda kullanılır.
#   cookie              -> token backend'in set ettiği httpOnly cookie'de tutulur (en güvenli).
#                          SADECE API aynı siteye ait bir alt-domain'den sunulduğunda
#                          (ör. https://api.gamelogd.net/api) aktifleştir; ayrıca
#                          NEXT_PUBLIC_API_URL'i o alt-domain'e ayarla.
NEXT_PUBLIC_AUTH_MODE=header
